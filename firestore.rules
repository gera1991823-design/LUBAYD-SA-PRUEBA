rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data;
    }

    function activeUser() {
      return signedIn() && ownProfile().active == true;
    }

    function role() {
      return activeUser() ? ownProfile().role : null;
    }

    function manager() {
      return role() == 'admin' || role() == 'supervisor';
    }

    function administrator() {
      return role() == 'admin';
    }

    function owns(data) {
      return signedIn()
             && ((('userId' in data) && data.userId == request.auth.uid)
                 || (('createdByUid' in data) && data.createdByUid == request.auth.uid));
    }

    match /usuarios/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || activeUser());
      allow create: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.role == 'operador'
                    && request.resource.data.active == false;
      allow update: if administrator();
      allow delete: if false;
    }

    match /partes/{recordId} {
      allow read: if activeUser() && (manager() || owns(resource.data));
      allow create: if role() == 'operador' && owns(request.resource.data);
      allow update: if activeUser() && (administrator() || (owns(resource.data) && owns(request.resource.data)));
      allow delete: if administrator();
    }

    match /asistencias/{recordId} {
      allow read: if activeUser() && (manager() || owns(resource.data));
      allow create: if role() == 'operador' && owns(request.resource.data);
      allow update: if activeUser() && (administrator() || (owns(resource.data) && owns(request.resource.data)));
      allow delete: if administrator();
    }

    match /descansos/{recordId} {
      allow read: if activeUser() && (manager() || owns(resource.data));
      allow create: if role() == 'operador' && owns(request.resource.data);
      allow update: if activeUser() && (administrator() || (owns(resource.data) && owns(request.resource.data)));
      allow delete: if administrator();
    }

    match /asistencia_fotos/{photoId} {
      allow read: if activeUser() && (manager() || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /descanso_fotos/{photoId} {
      allow read: if activeUser() && (manager() || resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /combustible_flujo_estado/{stateId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /combustible_flujo_movimientos/{movementId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /combustible_flujo_fotos/{photoId} {
      allow read: if activeUser();
      allow write: if false;
    }

    match /maquinas/{itemId} {
      allow read: if activeUser();
      allow create, update, delete: if administrator();
    }

    match /montes/{itemId} {
      allow read: if activeUser();
      allow create, update, delete: if administrator();
    }

    match /chats/{chatId} {
      allow read: if activeUser() && request.auth.uid in resource.data.participants;
      allow create: if activeUser()
                    && request.auth.uid in request.resource.data.participants
                    && request.resource.data.participants.size() == 2;
      allow update: if activeUser()
                    && request.auth.uid in resource.data.participants
                    && request.resource.data.participants == resource.data.participants;
      allow delete: if false;

      match /mensajes/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if activeUser() && request.auth.uid in parentChat().participants;
        allow create: if activeUser()
                      && request.auth.uid in parentChat().participants
                      && request.resource.data.senderId == request.auth.uid
                      && request.resource.data.receiverId in parentChat().participants
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 1000;
        allow update, delete: if false;
      }
    }

    match /push_tokens/{tokenId} {
      allow create, update: if activeUser() && request.resource.data.uid == request.auth.uid;
      allow delete: if activeUser() && resource.data.uid == request.auth.uid;
      allow read: if false;
    }

    match /offline_devices/{uid}/devices/{deviceId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
