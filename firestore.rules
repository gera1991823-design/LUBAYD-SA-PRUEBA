rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function myProfile() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn() && myProfile().data.active == true;
    }

    function isAdmin() {
      return activeUser() && myProfile().data.role == 'admin';
    }

    function isManager() {
      return activeUser() && myProfile().data.role in ['admin', 'supervisor'];
    }

    match /usuarios/{uid} {
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'operador'
        && request.resource.data.active == true;

      allow read: if signedIn() && (request.auth.uid == uid || activeUser());

      allow update: if isAdmin()
        || (activeUser()
          && request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nombre', 'updatedAt']));

      allow delete: if false;
    }

    match /partes/{partId} {
      allow create: if activeUser()
        && request.resource.data.createdByUid == request.auth.uid;

      allow read: if activeUser()
        && (resource.data.createdByUid == request.auth.uid || isManager());

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /asistencias/{attendanceId} {
      allow create: if activeUser()
        && request.resource.data.userId == request.auth.uid
        && attendanceId == request.auth.uid + '_' + request.resource.data.dateKey
        && request.resource.data.entrada is map
        && request.resource.data.salida == null;

      allow read: if activeUser()
        && (resource.data.userId == request.auth.uid || isManager());

      allow update: if isAdmin()
        || (activeUser()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.dateKey == resource.data.dateKey
          && resource.data.salida == null
          && request.resource.data.salida is map
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['salida', 'updatedAt']));

      allow delete: if isAdmin();
    }

    match /asistencia_fotos/{photoId} {
      allow create: if activeUser()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.dataUrl is string
        && request.resource.data.dataUrl.size() < 900000;

      allow read: if activeUser()
        && (resource.data.userId == request.auth.uid || isManager());

      allow update: if false;
      allow delete: if isAdmin();
    }

    match /asistencia_auditoria/{auditId} {
      allow create: if isAdmin()
        && request.resource.data.adminId == request.auth.uid;
      allow read: if isManager();
      allow update, delete: if false;
    }

    match /chats/{chatId} {
      allow create: if activeUser()
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members;

      allow read: if activeUser() && request.auth.uid in resource.data.members;

      allow update: if activeUser()
        && request.auth.uid in resource.data.members
        && request.resource.data.members == resource.data.members;

      allow delete: if false;

      match /mensajes/{messageId} {
        function chatData() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }

        allow create: if activeUser()
          && request.auth.uid in chatData().members
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.receiverId in chatData().members
          && request.resource.data.receiverId != request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;

        allow read: if activeUser() && request.auth.uid in chatData().members;

        allow update: if activeUser()
          && request.auth.uid == resource.data.receiverId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read', 'readAt']);

        allow delete: if false;
      }
    }

    match /push_tokens/{tokenId} {
      allow create: if activeUser()
        && request.resource.data.userId == request.auth.uid;

      allow read: if activeUser()
        && (resource.data.userId == request.auth.uid || isAdmin());

      allow update: if activeUser()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      allow delete: if activeUser()
        && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
