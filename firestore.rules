rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function activeUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.active == true;
    }

    function validLockedGps() {
      return request.resource.data.gps is map
        && request.resource.data.gps.keys().hasAll([
          'latitude',
          'longitude',
          'accuracy',
          'capturedAt',
          'capturedAtServer'
        ])
        && request.resource.data.gps.latitude is number
        && request.resource.data.gps.latitude >= -90
        && request.resource.data.gps.latitude <= 90
        && request.resource.data.gps.longitude is number
        && request.resource.data.gps.longitude >= -180
        && request.resource.data.gps.longitude <= 180
        && request.resource.data.gps.accuracy is number
        && request.resource.data.gps.accuracy >= 0
        && request.resource.data.gps.capturedAt is string
        && request.resource.data.gps.capturedAtServer == request.time;
    }

    match /usuarios/{userId} {
      // Cada persona puede crear su perfil inicial, siempre inactivo.
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.active == false
        && request.resource.data.email == request.auth.token.email;

      // El usuario puede consultar su propio estado de habilitacion.
      allow read: if signedIn() && request.auth.uid == userId;

      // La activacion se realiza desde Firebase Console, que no depende de estas reglas.
      allow update, delete: if false;
    }

    match /partes/{parteId} {
      // Solo usuarios habilitados pueden consultar la operacion compartida.
      allow read: if activeUser();

      // Cada parte queda asociado al usuario habilitado y exige GPS actual.
      allow create: if activeUser()
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.createdAtServer == request.time
        && validLockedGps();

      // Los partes son inmutables: no se permite editar la ubicacion ni otros datos.
      allow update: if false;

      // Solamente el autor habilitado puede eliminar su propio parte.
      allow delete: if activeUser()
        && resource.data.createdByUid == request.auth.uid;
    }
  }
}
